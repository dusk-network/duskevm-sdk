{
  "name": "@dusk/evm-sdk",
  "version": "0.1.0-beta.1",
  "description": "Typed Dusk and DuskEVM bridge transaction helpers, codecs, clients, and lifecycle primitives",
  "type": "module",
  "license": "MPL-2.0",
  "author": "Dusk Network B.V.",
  "keywords": [
    "dusk",
    "duskevm",
    "bridge",
    "ethereum",
    "evm",
    "op-stack",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dusk-network/duskevm-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/dusk-network/duskevm-sdk/issues"
  },
  "homepage": "https://github.com/dusk-network/duskevm-sdk#readme",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "docs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge/index.d.ts",
      "import": "./dist/bridge/index.js",
      "default": "./dist/bridge/index.js"
    },
    "./envelope": {
      "types": "./dist/envelope/index.d.ts",
      "import": "./dist/envelope/index.js",
      "default": "./dist/envelope/index.js"
    },
    "./l1": {
      "types": "./dist/l1/index.d.ts",
      "import": "./dist/l1/index.js",
      "default": "./dist/l1/index.js"
    },
    "./l2": {
      "types": "./dist/l2/index.d.ts",
      "import": "./dist/l2/index.js",
      "default": "./dist/l2/index.js"
    },
    "./status": {
      "types": "./dist/status/index.d.ts",
      "import": "./dist/status/index.js",
      "default": "./dist/status/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "check": "npm run check:generated && npm run typecheck && npm run test && npm run check:deno && npm run check:docs && npm run check:package && npm run check:jsr",
    "check:deno": "deno check --unstable-sloppy-imports src/index.ts",
    "check:docs": "node scripts/check-docs.mjs",
    "check:generated": "npm run check:l1-interface && npm run check:l2-abis",
    "check:jsr": "jsr publish --dry-run --allow-dirty",
    "check:l1-interface": "node scripts/check-l1-interface.mjs",
    "check:l2-abis": "npm run generate:l2-abis && git diff --exit-code -- src/l2/op-abis.ts",
    "check:package": "node scripts/check-package.mjs",
    "check:release-state": "node scripts/check-release-state.mjs",
    "import:l1-interface": "node scripts/generate-l1-interface.mjs",
    "generate:l2-abis": "node scripts/generate-l2-abis.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check:release-state && npm run check",
    "release:pack": "npm pack",
    "release:verify": "npm run check:release-state && npm run check && npm publish --dry-run --ignore-scripts --access public --tag beta",
    "smoke:local": "npm run build && node scripts/local-bridge-smoke.mjs",
    "smoke:local:dry-run": "npm run build && node scripts/local-bridge-smoke.mjs --dry-run",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@noble/curves": "1.9.1",
    "viem": "^2.54.3"
  },
  "devDependencies": {
    "@eth-optimism/contracts-bedrock": "0.17.3",
    "@types/node": "^24.0.0",
    "jsr": "0.14.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  }
}
